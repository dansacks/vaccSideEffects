. /*===========================================================================
> ===
>     Section 3b: Lasso to predict pca1 from pre-experiment variables
> =============================================================================
> =*/
. 
. /*---------------------------------------------------------------------------
> ---
>     3b.1 Recode reliable_* for non-users (structural missingness)
>          Missing means respondent never uses that source → code as 0 "N/A"
>          reliable_university is asked of all respondents, so no imputation ne
> eded.
> -----------------------------------------------------------------------------
> -*/
. 
. foreach src in doctor sm podcasts cdc news {
  2.     replace reliable_`src' = 0 if missing(reliable_`src') & !missing(info_
> `src')
  3.     assert !missing(reliable_`src') if !missing(info_`src')
  4.     label define rel_`src'_lbl 0 "N/A" 1 "Not reliable" 2 "Somewhat" 3 "Ye
> s", replace
  5.     label values reliable_`src' rel_`src'_lbl
  6. }
(798 real changes made)
(2,150 real changes made)
(2,791 real changes made)
(1,775 real changes made)
(2,347 real changes made)

. 
. /*---------------------------------------------------------------------------
> ---
>     3b.2 Recode info_* and follow_doctor: -1 means "No [source]" (a valid
>          category) but Stata's i. factor notation requires non-negative value
> s.
>          Remap -1 → 0 so 0 = "No [source]" serves as the base dummy category.
> -----------------------------------------------------------------------------
> -*/
. 
. foreach v in info_doctor info_sm info_podcasts info_cdc info_news info_univer
> sity follow_doctor {
  2.     replace `v' = 0 if `v' == -1
  3. }
(281 real changes made)
(0 real changes made)
(0 real changes made)
(0 real changes made)
(0 real changes made)
(0 real changes made)
(0 real changes made)

. 
. /*---------------------------------------------------------------------------
> ---
>     3b.3 Define additional predictors and expand variable list
> -----------------------------------------------------------------------------
> -*/
. 
. global lasso_extra "i.info_doctor i.info_sm i.info_podcasts i.info_cdc i.info
> _news"

. global lasso_extra "$lasso_extra i.info_university i.reliable_doctor i.reliab
> le_sm i.reliable_podcasts"

. global lasso_extra "$lasso_extra i.reliable_cdc i.reliable_news i.reliable_un
> iversity i.follow_doctor has_insurance"

. 
. * Expand factor notation to get full variable list (handles cond_* wildcard t
> oo)
. fvexpand $controls $lasso_extra

. local all_preds `r(varlist)'

