. /*===========================================================================
> ===
>     Section 3a: PCA on trust_trial and relevant_trial
> =============================================================================
> =*/
. 
. use "derived/merged_all.dta", clear

. 
. /*---------------------------------------------------------------------------
> ---
>     3a.1 Compute PCA on main sample
> -----------------------------------------------------------------------------
> -*/
. 
. pca trust_trial relevant_trial if main_sample == 1

