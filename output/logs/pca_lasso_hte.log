. /*===========================================================================
> ===
>     Section 3d: Plot — lincom CIs over pca1_hat grid [-2, 2]
> 
>     For each arm k at grid point x:
>       TE_k(x) = arm_k + x * (pca1_hat # arm_k)
>     lincom computes this linear combination along with its SE, giving exact 9
> 5% CIs.
> =============================================================================
> =*/
. 
. tempfile plot_data

. postfile phandle str10 arm str12 outcome float xval float te float ci_lo floa
> t ci_hi ///
>     using `plot_data', replace
(file /var/folders/_y/_xwy4y390t9bgphz7ts4mj540000gn/T//St92651.000001 not
    found)

. 
. foreach outcm in delta main_intent {
  2.     estimates restore m_`outcm'
  3.     forvalues xi = 0/40 {
  4.         local x = (`xi' - 20) / 10
  5.         foreach arm in industry academic personal {
  6.             lincom arm_`arm' + `x' * c.pca1_hat#c.arm_`arm'
  7.             post phandle ("`arm'") ("`outcm'") (`x') ///
>                 (`r(estimate)') ///
>                 (`r(estimate)' - 1.96*`r(se)') ///
>                 (`r(estimate)' + 1.96*`r(se)')
  8.         }
  9.     }
 10. }
