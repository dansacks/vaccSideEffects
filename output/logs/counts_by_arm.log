. use "derived/merged_all.dta", clear

. keep if main_sample==1
(13 observations deleted)

. 
. local outcomes delta post_trial main_intent link_click got_flu_vacc

. 
. file open _counts using "output/tables/counts_by_arm.tex", write replace

. 
. forvalues arm = 0/3 {
  2.     if `arm' == 0 local name "Control"
  3.     if `arm' == 1 local name "Industry"
  4.     if `arm' == 2 local name "Academic"
  5.     if `arm' == 3 local name "Representative"
  6. 
.     file write _counts "`name'"
  7.     foreach outcome of local outcomes {
  8.         count if arm_n == `arm' & !missing(`outcome')
  9.         file write _counts " & " %5.0fc (r(N))
 10.     }
 11.     file write _counts " \\" _n
 12. }
