end of do-file

. do "code/_set_controls.do"

. /*===========================================================================
> ===
>     Control Variables Definition
> 
>     Include this file in do-files that run regressions with control variables
> .
>     Sets globals: prior_beliefs, vacc_experience, demographics, controls
> =============================================================================
> =*/
. 
. * Prior beliefs from main survey
. global prior_beliefs "i.prior_self_placebo i.prior_self_vacc"

. 
. * Vaccine experiences from prescreen
. global vacc_experience "had_prior_covid_vacc had_prior_flu_vacc i.covid_vacc_
> reaction i.flu_vacc_reaction"

. 
. * Demographics from main survey (with missing indicators)
. global demographics "i.age i.gender i.education i.income i.race i.ethnicity i
> .polviews"

. global demo_miss "age_miss gender_miss education_miss income_miss race_miss e
> thnicity_miss polviews_miss"

. 
. * Prescreen control missing indicators (from clean_prescreen.do, renamed in m
> erge)
. global pre_miss "trust_govt_miss pre_had_prior_covid_vacc_miss pre_had_prior_
> flu_vacc_miss pre_covid_vacc_reaction_miss pre_flu_vacc_reaction_miss"

. 
. * All controls combined
. global controls "$prior_beliefs i.pre_vacc_intent $vacc_experience $demograph
> ics i.trust_govt $demo_miss $pre_miss cond_*"

. 
end of do-file

. 
. /*---------------------------------------------------------------------------
> ---
>     1. Load data
> -----------------------------------------------------------------------------
> -*/
. 
. use "derived/merged_all.dta", clear

. keep if main_sample==1
(13 observations deleted)

. 
. label var arm_industry "Industry"

. label var arm_academic "Academic"

. label var arm_personal "Representative"

. 
. /*---------------------------------------------------------------------------
> ---
>     2. Columns 1-2: all arms, trust and relevance of trial
> -----------------------------------------------------------------------------
> -*/
. 
. eststo clear

. 
. foreach y in trust_trial relevant_trial {
  2.     regress `y' arm_industry arm_academic arm_personal $controls, robust
  3.     sum `y' if arm_control == 1
  4.     estadd scalar cm = r(mean)
  5.     eststo m_`y'
  6. }
